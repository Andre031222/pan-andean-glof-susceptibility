# =============================================================================
# GLOF Andes Project - Environment Variables Template
# Copy this file to .env and fill in your credentials
# =============================================================================

# NASA Earthdata (for ASTER DEM, Landsat)
# Register at: https://urs.earthdata.nasa.gov/
EARTHDATA_USERNAME=your_username_here
EARTHDATA_PASSWORD=your_password_here

# Copernicus Open Access Hub (for Sentinel-2)
# Register at: https://scihub.copernicus.eu/dhus/#/self-registration
COPERNICUS_USER=your_username_here
COPERNICUS_PASSWORD=your_password_here

# Google Earth Engine (optional)
# Follow: https://developers.google.com/earth-engine/guides/python_install
GEE_SERVICE_ACCOUNT=your_service_account@project.iam.gserviceaccount.com
GEE_KEY_FILE=path/to/your/key.json

# Microsoft Planetary Computer (optional, no auth needed for most data)
# PC_SDK_SUBSCRIPTION_KEY=your_key_here
