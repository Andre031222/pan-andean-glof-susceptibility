[Unit]
Description=GLOF Andes inventory validation API (FastAPI/uvicorn)
After=network.target postgresql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/glof-andes/backend
EnvironmentFile=/opt/glof-andes/backend/.env
ExecStart=/opt/glof-andes/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8077
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
